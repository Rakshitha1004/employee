# Environment Configuration

# Spring Boot Configuration
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=4000

# Database Configuration
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/employee_db?createDatabaseIfNotExist=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=root
SPRING_JPA_HIBERNATE_DDL_AUTO=create-drop

# JWT Configuration
APP_JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
APP_JWT_EXPIRATION=86400000

# CORS Configuration
APP_FRONTEND_ORIGIN=http://localhost:5173

# MySQL Configuration
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=employee_db
MYSQL_USER=employee
MYSQL_PASSWORD=employee123
